{
  "schemaVersion": 1,
  "id": "minetrigger",
  "version": "${version}",
  "name": "MineTrigger",
  "description": "ワールドトリガーの戦闘システムをMinecraftで再現するFabric Mod",
  "authors": ["sigulog"],
  "license": "ARR",
  "environment": "*",
  "entrypoints": {
    "main": ["com.sigulog.minetrigger.MineTriggerMod"],
    "client": ["com.sigulog.minetrigger.client.MineTriggerClient"]
  },
  "mixins": ["minetrigger.mixins.json", "minetrigger.client.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "~1.21.1",
    "java": ">=21"
  }
}
